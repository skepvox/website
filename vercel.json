{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).jsonl",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/x-ndjson; charset=utf-8"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/(.*).md",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex"
        }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=604800, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "skepvox.com"
        }
      ],
      "destination": "https://www.skepvox.com/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*/index.html",
      "destination": "/:path*/",
      "permanent": true
    },
    {
      "source": "/:path*.html",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/enem",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/enem/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/enem-sandbox",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/enem-sandbox/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/demos",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/demos/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/demos-data",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/demos-data/:path*",
      "destination": "/",
      "permanent": true
    }
  ]
}
